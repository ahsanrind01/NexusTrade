{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "scheme": "nexustrade",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.nexustrade.app",
          "enableGooglePay": true
        }
      ]
    ],
    "android": {
      "package": "com.ahsanrind.frontend"
    },
    "ios": {
      "bundleIdentifier": "com.ahsanrind.frontend"
    },
    "extra": {
      "eas": {
        "projectId": "ad2aa7b1-b7ef-4a44-ad0f-c1c7a6129d39"
      }
    }
  }
}
