      </View>
    </Animated.View>
  );
});

const SearchBar = memo(function SearchBar({
  value, focused, onChangeText, onFocus, onBlur, onClear,
}: {
  value: string; focused: boolean;
  onChangeText: (t: string) => void; onFocus: () => void; onBlur: () => void; onClear: () => void;
}) {
  return (
