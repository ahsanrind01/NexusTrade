// ─── Blur fallback ────────────────────────────────────────────────────────────
let BlurView: any = null;
try { BlurView = require('expo-blur').BlurView; } catch { BlurView = null; }

const { width } = Dimensions.get('window');

// ─── Design tokens (identical to Home) ───────────────────────────────────────
