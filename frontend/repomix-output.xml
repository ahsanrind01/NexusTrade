          returnKeyType="search"
        />
        {value.length > 0 && (
          <TouchableOpacity onPress={onClear}>
            <Text style={styles.searchClear}>✕</Text>
          </TouchableOpacity>
        )}
      </GlassPanel>
    </Animated.View>
