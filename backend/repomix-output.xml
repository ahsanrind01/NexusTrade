  };
}

export interface SimulateCryptoDepositRequest {
  transactionId: string;
}

// ---- Orders ----

export type OrderSide = 'buy' | 'sell';
export type OrderStatus = 'open' | 'filled' | 'cancelled' | 'partial';

export interface Order {
  id: string;
  symbol: string;
